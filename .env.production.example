# ===========================================================
# CompportIQ Production Environment Variables
# ===========================================================
# This file documents ALL required and optional env vars for production.
# Copy to .env and fill in real values. NEVER commit real secrets.
#
# On GCP Cloud Run, most of these are injected via Secret Manager
# (see infra/terraform/modules/secrets/ and cloudrun/).

# ─── Core ─────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=30000

# ─── Database (GCP Cloud SQL — PostgreSQL 16) ─────────────────
# Injected from Secret Manager in Cloud Run. For local use:
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://compportiq_admin:CHANGE_ME@/compportiq?host=/cloudsql/PROJECT:REGION:INSTANCE

# ─── Redis (GCP Memorystore) ─────────────────────────────────
# Injected from Secret Manager in Cloud Run. For local use:
REDIS_URL=redis://:AUTH_STRING@MEMORYSTORE_HOST:6379

# ─── API ──────────────────────────────────────────────────────
API_PORT=4000
CORS_ORIGINS=https://compportiq.ai
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_EXPIRATION=1d

# ─── Next.js Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://compportiq.ai
NEXTAUTH_URL=https://compportiq.ai
NEXTAUTH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
NEXT_TELEMETRY_DISABLED=1

# ─── AI Provider ─────────────────────────────────────────────
# Options: anthropic | azure | openai
AI_PROVIDER=anthropic

# Anthropic (Claude Opus 4) — primary AI provider
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-6

# Azure OpenAI (legacy — kept for fallback)
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Azure AD SSO (Entra ID) ─────────────────────────────────
AZURE_AD_CLIENT_ID=CHANGE_ME
AZURE_AD_CLIENT_SECRET=CHANGE_ME
AZURE_AD_TENANT_ID=CHANGE_ME
AZURE_AD_REDIRECT_URI=https://compportiq.ai/api/v1/auth/azure/callback

# ─── Integration Hub Encryption ──────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Injected from Secret Manager as INTEGRATION_ENCRYPTION_KEY in Cloud Run
INTEGRATION_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX

# ─── Compport Bridge ─────────────────────────────────────────
COMPPORT_MODE=standalone

# ─── Production Seed (first deploy only) ─────────────────────
# Used by `pnpm --filter @compensation/database seed:prod`
ADMIN_EMAIL=admin@compportiq.ai
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

