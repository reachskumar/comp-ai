{
  "name": "compensation-platform",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "db:migrate": "pnpm --filter @compensation/database db:migrate",
    "db:seed": "pnpm --filter @compensation/database db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "hono@<4.11.10": "4.11.10",
      "ajv@>=8.0.0 <8.18.0": "8.18.0",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "lodash@<=4.17.22": "4.17.23",
      "serialize-javascript@<=7.0.2": "7.0.3",
      "tmp@<=0.2.3": "0.2.4",
      "webpack@>=5.49.0 <5.104.1": "5.104.1",
      "rollup@>=4.0.0 <4.59.0": "4.59.0"
    }
  }
}
